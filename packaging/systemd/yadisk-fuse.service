[Unit]
Description=Yandex Disk FUSE mount lifecycle
After=yadiskd.service
Requires=yadiskd.service

[Service]
Type=simple
Environment="YADISK_SYNC_DIR=%h/Yandex Disk"
ExecStart=/bin/sh -lc 'exec "$HOME/.local/bin/yadisk-fuse" --mount "${YADISK_SYNC_DIR:-$HOME/Yandex Disk}"'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
